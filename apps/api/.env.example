# Coach Keith AI — API Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# REQUIRED
# ============================================================

# Anthropic API key for Claude AI coaching responses
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret for auth tokens (32+ chars, random)
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# ============================================================
# PI-BRAIN (Local Persistence)
# ============================================================

# PostgreSQL connection for Pi-Brain memory storage
# Local development: points to docker-compose pgvector service
PI_BRAIN_DATABASE_URL=postgresql://navigator:navigator@localhost:5433/coach_keith_brain

# ============================================================
# OPTIONAL — Development Defaults
# ============================================================

PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=30d

# CORS — allow all in development
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ============================================================
# FUTURE — Google Cloud Production
# ============================================================

# Uncomment when deploying to Cloud Run:
# FIRESTORE_URL=https://firestore.googleapis.com/v1/projects/coach-keith-prod
# GCS_BUCKET=coach-keith-brain
# GOOGLE_PROJECT_ID=coach-keith-prod
# PI_BRAIN_URL=https://brain.coachkeith.app/sse
